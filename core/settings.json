{
  "outputStyle": "concise",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/neural/dangerous-actions-blocker.sh",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Bash|Write|Edit|WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/neural/prompt-injection-detector.sh",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Read|Edit|Write|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/neural/sensitive-file-guard.sh",
            "timeout": 2000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/neural/output-scanner.sh",
            "timeout": 3000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/neural/pre-compact.sh",
            "timeout": 30000
          }
        ]
      }
    ]
  }
}
